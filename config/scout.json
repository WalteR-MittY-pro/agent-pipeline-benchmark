{
    "language_extensions": {
        "Python": [".py"],
        "Rust": [".rs"],
        "C": [".c", ".h"],
        "C++": [".cpp", ".hpp", ".cc", ".cxx", ".hxx"],
        "JavaScript": [".js", ".jsx", ".mjs", ".cjs"],
        "TypeScript": [".ts", ".tsx", ".mts", ".cts"],
        "Go": [".go"],
        "Java": [".java"],
        "PHP": [".php"],
        "Kotlin": [".kt", ".kts"],
        "Swift": [".swift"],
        "C#": [".cs"]
    },
    "ignore_extensions": [
        ".json", ".yaml", ".yml", ".md", ".xml", ".toml", ".ini",
        ".lock", ".txt", ".rst", ".cfg", ".gitignore", ".dockerignore",
        ".mod", ".sum", ".lock", ".svg", ".png", ".jpg", ".gif"
    ],
    "test_patterns": [
        "_test.go", ".test.ts", ".test.js", ".spec.ts", ".spec.js",
        "Test.java", "Tests.java", "*Tests.kt", "*Test.kt",
        "test_", "_test.py", ".test.py",
        "_test.cpp", "_test.cxx", "_test.cc", "_test.c",
        "test_*.rs", "*_tests.rs",
        "*_spec.rb", ".spec.rb",
        "_test.php", "Test.php", "*Test.php",
        "*_tests.dart", "*_test.dart",
        "_test.swift", "*Tests.swift", "*Spec.swift",
        "Test*.cs", "*Tests.cs", "*Test.cs",
        "/test/", "/tests/", "/__tests__/", "/testdata/", "/spec/"
    ],
    "pr_criteria": {
        "max_files_changed": 10,
        "min_languages": 2,
        "require_test_file": true
    },
    "pr_filter": {
        "state": "all",
        "sort": "updated",
        "direction": "desc",
        "limit_per_repo": 100
    },
    "output": {
        "json": "data/scout/candidate_prs.json",
        "csv": "data/scout/candidate_prs.csv"
    },
    "api": {
        "per_page": 100,
        "timeout": 30,
        "sleep_interval": 0.5,
        "retry_total": 3,
        "secondary_rate_wait": 60
    }
}
